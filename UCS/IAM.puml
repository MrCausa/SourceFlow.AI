@startuml "IAM System Use Cases"
left to right direction
skinparam packageStyle rectangle


actor "PYME Manager (Owner)" as Owner
actor "Business Worker (Employee)" as Worker
actor "Platform Admin" as Admin


rectangle "Identity & Access Management (IAM)" {
  (UC01: Register Account) as UC1
  (UC02: Login / Authenticate) as UC2
  (UC03: Manage User Profile) as UC3
  (UC04: Reset Password) as UC4
}


Owner --> UC1
Owner --> UC2
Owner --> UC3


Worker --> UC2
Worker --> UC3


Admin --> UC2
Admin --> UC4


UC1 ..> UC2 : <<include>>
@enduml
